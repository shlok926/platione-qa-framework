# ==============================================================================
# Platione Sales Assist QA Automation Framework — Environment Template
# Copy this file to .env.qa, .env.staging, or .env.prod-like and fill in values.
# ==============================================================================

# Application & API Base URLs
APP_BASE_URL=http://localhost:4200
API_BASE_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=platione_test
DB_USER=qa_user
DB_PASSWORD=your_db_password_here

# Test Credentials
TEST_USER_EMAIL=qa@platione.com
TEST_USER_PASSWORD=your_test_user_password_here

# Framework & Execution Controls
# LOG_LEVEL options: debug, info, warn, error
LOG_LEVEL=info
# ENVIRONMENT options: qa, staging, prod-like
ENVIRONMENT=qa
